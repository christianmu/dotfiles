# local/private machine overrides (not tracked)
# -----------------------------------------------------------------------------
# OS / Editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*~
*.swp
*.swo
*.tmp

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# Secrets / local overrides (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.crt

# -----------------------------------------------------------------------------
# User-local / machine-specific files
# -----------------------------------------------------------------------------
.bashrc.local
.profile.local

# -----------------------------------------------------------------------------
# bin: external tools & binaries (not versioned)
# -----------------------------------------------------------------------------
bin/_external/
bin/**/pup
bin/**/pup.*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------------------------
# Node / tooling caches (future-proof)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Zed / Editor state (config is ok, caches not)
# -----------------------------------------------------------------------------
.zed/cache/
.zed/logs/

# -----------------------------------------------------------------------------
# Temporary / experiments
# -----------------------------------------------------------------------------
*.bak
*.old
